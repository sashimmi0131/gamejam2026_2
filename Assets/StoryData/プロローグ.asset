    StoryText: "\u4FFA\u306F\u90E8\u9577\u3068\u3057\u3066\u3001\u6700\u5F8C\u306E\u90E8\u5BA4\u306E\u7247\u3065\u3051\u3092\u3057\u3066\u3044\u305F\u3002"
