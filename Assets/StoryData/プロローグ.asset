  - Background: {fileID: 5274173733187224425, guid: 7c6b5f8056ac86443b620ac79ab83811, type: 3}
    CharacterImage: {fileID: -4818643248354753769, guid: cd6f5392b0e9131418d30f75db003c82, type: 3}
    StoryText: "\u5F8C\u8F29\u305F\u3061\u306F\u3059\u3067\u306B\u5E30\u3063\u3066\u3057\u307E\u3044\u3001\u6B8B\u3063\u3066\u3044\u308B\u306E\u306F\u30DE\u30CD\u30FC\u30B8\u30E3\u30FC\u306E\u300E\u671D\u6BD4\u5948\u7F8E\u6708\u300F\u3060\u3051\u3060\u3063\u305F\u3002"
